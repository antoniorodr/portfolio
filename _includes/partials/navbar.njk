<nav class="navbar">
  <div class="navbar-inner">
    <a href="/{{ locale }}/" class="navbar-brand">
      <span class="brand-prompt">&gt;</span> {{ site.name }}
    </a>

    <div class="navbar-links">
      <a href="#projects" class="nav-link">{{ "nav.projects" | t(locale) }}</a>
      <a href="#resume" class="nav-link">{{ "nav.resume" | t(locale) }}</a>

      <div class="nav-dropdown">
        <button class="nav-link nav-dropdown-trigger" aria-haspopup="true" aria-expanded="false">
          {{ "nav.downloadCv" | t(locale) }}
          <span class="dropdown-arrow"></span>
        </button>
        <div class="dropdown-menu">
          <a href="{{ site.cv.en }}" class="dropdown-item" target="_blank" rel="noopener">{{ "nav.cvEnglish" | t(locale)
            }}</a>
          <a href="{{ site.cv.no }}" class="dropdown-item" target="_blank" rel="noopener">{{ "nav.cvNorwegian" |
            t(locale) }}</a>
        </div>
      </div>

      <a href="mailto:{{ site.email }}" class="nav-link">{{ "nav.contact" | t(locale) }}</a>

      <div class="nav-social">
        <a href="{{ site.github }}" class="social-link" target="_blank" rel="noopener" aria-label="GitHub">
          <svg width="20" height="20">
            <use href="/static/sprites.svg#icon-github" />
          </svg>
        </a>
        <a href="{{ site.linkedin }}" class="social-link" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg width="20" height="20">
            <use href="/static/sprites.svg#icon-linkedin" />
          </svg>
        </a>
      </div>

      <button class="lang-toggle" id="langToggle" aria-label="Toggle language">
        <span class="lang-label">{% if locale == "en" %}NO{% else %}EN{% endif %}</span>
      </button>

      <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
        <span class="theme-icon sun">
          <svg width="18" height="18">
            <use href="/static/sprites.svg#icon-sun" />
          </svg>
        </span>
        <span class="theme-icon moon">
          <svg width="18" height="18">
            <use href="/static/sprites.svg#icon-moon" />
          </svg>
        </span>
      </button>
    </div>

    <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobileMenu">
    <a href="#projects" class="mobile-nav-link">{{ "nav.projects" | t(locale) }}</a>
    <a href="#resume" class="mobile-nav-link">{{ "nav.resume" | t(locale) }}</a>
    <div class="mobile-dropdown">
      <button class="mobile-nav-link mobile-dropdown-trigger" aria-haspopup="true" aria-expanded="false">
        {{ "nav.downloadCv" | t(locale) }}
        <span class="dropdown-arrow"></span>
      </button>
      <div class="mobile-dropdown-menu">
        <a href="{{ site.cv.en }}" class="mobile-nav-link dropdown-item" target="_blank" rel="noopener">{{
          "nav.cvEnglish" | t(locale) }}</a>
        <a href="{{ site.cv.no }}" class="mobile-nav-link dropdown-item" target="_blank" rel="noopener">{{
          "nav.cvNorwegian" | t(locale) }}</a>
      </div>
    </div>
    <a href="mailto:{{ site.email }}" class="mobile-nav-link">{{ "nav.contact" | t(locale) }}</a>
    <div class="mobile-social">
      <a href="{{ site.github }}" class="social-link" target="_blank" rel="noopener" aria-label="GitHub">
        <svg width="20" height="20">
          <use href="/static/sprites.svg#icon-github" />
        </svg>
      </a>
      <a href="{{ site.linkedin }}" class="social-link" target="_blank" rel="noopener" aria-label="LinkedIn">
        <svg width="20" height="20">
          <use href="/static/sprites.svg#icon-linkedin" />
        </svg>
      </a>
      <button class="lang-toggle" id="mobileLangToggle" aria-label="Toggle language">
        <span class="lang-label">{% if locale == "en" %}NO{% else %}EN{% endif %}</span>
      </button>
      <button class="theme-toggle" id="mobileThemeToggle" aria-label="Toggle theme">
        <span class="theme-icon sun">
          <svg width="18" height="18">
            <use href="/static/sprites.svg#icon-sun" />
          </svg>
        </span>
        <span class="theme-icon moon">
          <svg width="18" height="18">
            <use href="/static/sprites.svg#icon-moon" />
          </svg>
        </span>
      </button>
    </div>
  </div>
</nav>
