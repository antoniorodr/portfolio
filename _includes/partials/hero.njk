<section class="hero" id="home">
  <div class="container">
    <div class="hero">
      <div class="hero-avatar">
        <img src="{{ site.avatar }}" alt="{{ site.name }}" class="avatar-img" loading="eager">
      </div>
      <div class="hero-content">
        <p class="hero-greeting">{{ "hero.greeting" | t(locale) }}</p>
        <h1 class="hero-name">{{ site.name }}</h1>
        <p class="hero-title">{{ site.title[locale] }}</p>
        <p class="hero-bio">
          {{ site.bio[locale] }}
        </p>
        <div class="hero-actions">
          <a href="#projects" class="btn btn-primary">{{ "hero.viewProjects" | t(locale) }}</a>
          <a href="mailto:{{ site.email }}" class="btn btn-secondary">{{ "hero.getInTouch" | t(locale) }}</a>
        </div>
      </div>
    </div>
  </div>
</section>
