<section id="projects">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Projects</h2>
      <p class="section-subtitle">A selection of things I've built and contributed to</p>
    </div>

    <div class="projects-grid" id="projectsGrid">
      {% for project in projects %}
      <article class="project-card" data-index="{{ loop.index0 }}">
        {% if project.image %}
        <img src="{{ project.image }}" alt="{{ project.name }}" class="project-image" loading="lazy">
        {% endif %}
        <div class="project-content">
          {% if project.highlight %}
          <div class="project-highlight">
            <svg width="14" height="14"><use href="/static/sprites.svg#icon-star"/></svg>
            {{ project.highlight }}
          </div>
          {% endif %}
          <span class="project-type">{{ project.type }}</span>
          <h3 class="project-name">
            {% if project.links.website %}
            <a href="{{ project.links.website }}" target="_blank" rel="noopener">{{ project.name }}</a>
            {% elif project.links.demo %}
            <a href="{{ project.links.demo }}" target="_blank" rel="noopener">{{ project.name }}</a>
            {% else %}
            {{ project.name }}
            {% endif %}
          </h3>
          <p class="project-description">{{ project.description }}</p>
          <div class="project-tech">
            {% for tech in project.tech %}
            <span class="tech-tag">{{ tech }}</span>
            {% endfor %}
          </div>
          <div class="project-actions">
            <div class="project-links">
              {% if project.links.github %}
              <a href="{{ project.links.github }}" class="project-link" target="_blank" rel="noopener">
                <svg width="16" height="16"><use href="/static/sprites.svg#icon-github"/></svg>
                GitHub
              </a>
              {% endif %}
              {% if project.links.website %}
              <a href="{{ project.links.website }}" class="project-link" target="_blank" rel="noopener">
                <svg width="16" height="16"><use href="/static/sprites.svg#icon-external"/></svg>
                Website
              </a>
              {% endif %}
              {% if project.links.demo %}
              <a href="{{ project.links.demo }}" class="project-link" target="_blank" rel="noopener">
                <svg width="16" height="16"><use href="/static/sprites.svg#icon-external"/></svg>
                Live Demo
              </a>
              {% endif %}
            </div>
            <button class="btn-read-more" onclick="openProjectModal({{ loop.index0 }})">
              Read more
              <svg width="14" height="14"><use href="/static/sprites.svg#icon-arrow-right"/></svg>
            </button>
          </div>
        </div>
      </article>
      {% endfor %}
    </div>

    <div class="pagination" id="pagination">
      <button class="pagination-btn" id="prevBtn" onclick="changePage(-1)" disabled>Previous</button>
      <span class="pagination-info" id="pageInfo">Page 1 of 3</span>
      <button class="pagination-btn" id="nextBtn" onclick="changePage(1)">Next</button>
    </div>
  </div>
</section>

<div class="modal-overlay" id="coursesModal" onclick="closeCoursesModal(event)">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h3 class="modal-title">Completed Courses</h3>
      <button class="modal-close" onclick="closeCoursesModal()" aria-label="Close modal">
        <svg width="24" height="24"><use href="/static/sprites.svg#icon-close"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <ul class="courses-list">
        {% for course in courses %}
        <li>
          <a href="{{ course.url }}" target="_blank" rel="noopener" class="course-link">
            {{ course.name }}
          </a>
        </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</div>

<div class="modal-overlay" id="projectModal" onclick="closeProjectModal(event)">
  <div class="modal modal-lg" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h3 class="modal-title" id="projectModalTitle"></h3>
      <button class="modal-close" onclick="closeProjectModal()" aria-label="Close modal">
        <svg width="24" height="24"><use href="/static/sprites.svg#icon-close"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <div id="projectModalContent"></div>
    </div>
  </div>
</div>

<script>
window.PROJECTS_DATA = {{ projects | dump | safe }};
</script>
