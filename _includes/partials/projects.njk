<section id="projects">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Projects</h2>
      <p class="section-subtitle">A selection of things I've built and contributed to</p>
    </div>

    <div class="projects-grid" id="projectsGrid">
      {% for project in projects %}
      <article class="project-card" data-index="{{ loop.index0 }}">
        {% if project.image %}
        <img src="{{ project.image }}" alt="{{ project.name }}" class="project-image" loading="lazy">
        {% endif %}
        <div class="project-content">
          {% if project.highlight %}
          <div class="project-highlight">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            {{ project.highlight }}
          </div>
          {% endif %}
          <span class="project-type">{{ project.type }}</span>
          <h3 class="project-name">
            {% if project.links.website %}
            <a href="{{ project.links.website }}" target="_blank" rel="noopener">{{ project.name }}</a>
            {% elif project.links.demo %}
            <a href="{{ project.links.demo }}" target="_blank" rel="noopener">{{ project.name }}</a>
            {% else %}
            {{ project.name }}
            {% endif %}
          </h3>
          <p class="project-description">{{ project.description }}</p>
          <div class="project-tech">
            {% for tech in project.tech %}
            <span class="tech-tag">{{ tech }}</span>
            {% endfor %}
          </div>
          <div class="project-actions">
            <div class="project-links">
              {% if project.links.github %}
              <a href="{{ project.links.github }}" class="project-link" target="_blank" rel="noopener">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                GitHub
              </a>
              {% endif %}
              {% if project.links.website %}
              <a href="{{ project.links.website }}" class="project-link" target="_blank" rel="noopener">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                Website
              </a>
              {% endif %}
              {% if project.links.demo %}
              <a href="{{ project.links.demo }}" class="project-link" target="_blank" rel="noopener">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                Live Demo
              </a>
              {% endif %}
            </div>
            <button class="btn-read-more" onclick="openProjectModal({{ loop.index0 }})">
              Read more
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            </button>
          </div>
        </div>
      </article>
      {% endfor %}
    </div>

    <div class="pagination" id="pagination">
      <button class="pagination-btn" id="prevBtn" onclick="changePage(-1)" disabled>Previous</button>
      <span class="pagination-info" id="pageInfo">Page 1 of 3</span>
      <button class="pagination-btn" id="nextBtn" onclick="changePage(1)">Next</button>
    </div>
  </div>
</section>

<div class="modal-overlay" id="projectModal" onclick="closeProjectModal(event)">
  <div class="modal modal-lg" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h3 class="modal-title" id="projectModalTitle"></h3>
      <button class="modal-close" onclick="closeProjectModal()" aria-label="Close modal">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="modal-body">
      <div id="projectModalContent"></div>
    </div>
  </div>
</div>

<script>
window.PROJECTS_DATA = {{ projects | dump | safe }};
</script>
